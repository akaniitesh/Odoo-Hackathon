{
  "name": "transitops-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run start --workspace=server\"",
    "start:server": "npm run start --workspace=server",
    "start:client": "npm run dev --workspace=client",
    "seed:dev": "npm run seed:dev --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
